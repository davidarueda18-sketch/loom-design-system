{
  "name": "@loom-sdc/design-system",
  "version": "0.5.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/index.core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs"
    },
    "./elements": {
      "types": "./dist/index.elements.d.ts",
      "import": "./dist/elements.mjs",
      "require": "./dist/elements.cjs"
    },
    "./custom-elements": {
      "types": "./dist/index.custom-elements.d.ts",
      "import": "./dist/custom-elements.mjs",
      "require": "./dist/custom-elements.cjs"
    },
    "./react-jsx": {
      "types": "./dist/react-jsx.d.ts",
      "import": "./dist/react-jsx.mjs",
      "require": "./dist/react-jsx.cjs"
    },
    "./elements/*": {
      "types": "./dist/elements/*.d.ts",
      "import": "./dist/elements/*.mjs",
      "require": "./dist/elements/*.cjs"
    },
    "./style.css": "./dist/style.css",
    "./fonts.css": "./dist/fonts.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/style.css",
    "dist/fonts.css",
    "dist/custom-elements.mjs",
    "dist/custom-elements.cjs",
    "dist/elements.mjs",
    "dist/elements.cjs",
    "dist/elements/*.mjs",
    "dist/elements/*.cjs"
  ],
  "scripts": {
    "build:lib": "vite build --config vite.lib.config.ts",
    "release": "npm run build:lib && npm publish --access public",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project storybook",
    "figma:publish": "figma connect publish"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/code-connect": "^1.4.4",
    "@heroicons/react": "^2.2.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.1",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
